FROM ghcr.io/railwayapp/nixpacks:ubuntu-1745885067

ENTRYPOINT ["/bin/bash", "-l", "-c"]
WORKDIR /app/


COPY .nixpacks/nixpkgs-ffeebf0acf3ae8b29f8c7049cd911b9636efd7e7.nix .nixpacks/nixpkgs-ffeebf0acf3ae8b29f8c7049cd911b9636efd7e7.nix
RUN nix-env -if .nixpacks/nixpkgs-ffeebf0acf3ae8b29f8c7049cd911b9636efd7e7.nix && nix-collect-garbage -d


ARG BUILDKIT_DOCKERFILE_CHECK CI NIXPACKS_METADATA NODE_ENV NPM_CONFIG_PRODUCTION OPENWEATHER_API_KEY RAILWAY_ENVIRONMENT RAILWAY_ENVIRONMENT_ID RAILWAY_ENVIRONMENT_NAME RAILWAY_PRIVATE_DOMAIN RAILWAY_PROJECT_ID RAILWAY_PROJECT_NAME RAILWAY_PUBLIC_DOMAIN RAILWAY_SERVICE_ID RAILWAY_SERVICE_NAME RAILWAY_SERVICE_SCOOP_URL RAILWAY_STATIC_URL
ENV BUILDKIT_DOCKERFILE_CHECK=$BUILDKIT_DOCKERFILE_CHECK CI=$CI NIXPACKS_METADATA=$NIXPACKS_METADATA NODE_ENV=$NODE_ENV NPM_CONFIG_PRODUCTION=$NPM_CONFIG_PRODUCTION OPENWEATHER_API_KEY=$OPENWEATHER_API_KEY RAILWAY_ENVIRONMENT=$RAILWAY_ENVIRONMENT RAILWAY_ENVIRONMENT_ID=$RAILWAY_ENVIRONMENT_ID RAILWAY_ENVIRONMENT_NAME=$RAILWAY_ENVIRONMENT_NAME RAILWAY_PRIVATE_DOMAIN=$RAILWAY_PRIVATE_DOMAIN RAILWAY_PROJECT_ID=$RAILWAY_PROJECT_ID RAILWAY_PROJECT_NAME=$RAILWAY_PROJECT_NAME RAILWAY_PUBLIC_DOMAIN=$RAILWAY_PUBLIC_DOMAIN RAILWAY_SERVICE_ID=$RAILWAY_SERVICE_ID RAILWAY_SERVICE_NAME=$RAILWAY_SERVICE_NAME RAILWAY_SERVICE_SCOOP_URL=$RAILWAY_SERVICE_SCOOP_URL RAILWAY_STATIC_URL=$RAILWAY_STATIC_URL

# setup phase
# noop

# install phase
ENV NIXPACKS_PATH=/app/node_modules/.bin:$NIXPACKS_PATH
COPY . /app/.
RUN --mount=type=cache,id=s/7b1d044a-4820-4c44-b885-516db05fcbfe-/root/npm,target=/root/.npm npm i

# build phase
COPY . /app/.
RUN --mount=type=cache,id=s/7b1d044a-4820-4c44-b885-516db05fcbfe-node_modules/cache,target=/app/node_modules/.cache npm ci --prefix backend && npm ci --prefix frontend && npm run build --prefix frontend


RUN printf '\nPATH=/app/node_modules/.bin:$PATH' >> /root/.profile


# start
COPY . /app

CMD ["npm start --prefix backend"]

