# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Build output
frontend/dist/

# SQLite database (regenerated on startup)
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# Generated branded cards (regenerated on demand from articles table)
backend/data/cards/

# VAPID private key — auto-generated on first boot if VAPID_*_KEY env vars
# unset; treat like any other secret and never commit.
backend/data/vapid.json

# Threads long-lived token — persisted by threadsClient.js on first boot.
# Contains the access token + expiry; treat like a secret.
backend/data/threads-token.json

# Logs
*.log
backend/logs/

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
